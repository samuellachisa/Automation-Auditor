# API keys / local (never commit .env; copy to .env and set at least one)
# Local Ollama (e.g. Qwen): set OLLAMA_MODEL and run "ollama run qwen2.5"
OLLAMA_MODEL=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_VISION_MODEL=qwen2-vl (optional; for VisionInspector diagram analysis)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Optional: override Gemini model (default: gemini-2.5-flash). Use gemini-2.0-flash if 2.5 is unavailable.
# GEMINI_MODEL=gemini-2.0-flash

# LangSmith (optional; set for tracing)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=automation-auditor
